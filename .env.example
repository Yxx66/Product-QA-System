# ====================
# LLM 模型配置
# ====================
OPENAI_API_KEY=your-dashscope-api-key-here
OPENAI_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
MODEL=qwen-plus
ITEM_MODEL=qwen-flash

# ====================
# Milvus 向量数据库
# ====================
MILVUS_URL=http://localhost:19530
CHUNKS_COLLECTION=knowledge_chunks
ITEM_NAME_COLLECTION=knowledge_item_names
ENTITY_NAME_COLLECTION=knowledge_entity_names

# ====================
# Neo4j 图数据库
# ====================
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=neo4j123456
NEO4J_DATABASE=neo4j

# ====================
# MongoDB 文档数据库
# ====================
MONGO_URL=mongodb://admin:admin123@localhost:27017
MONGO_DB_NAME=knowledge_db
MONGO_HISTORY_COLLECTION=chat_history

# ====================
# MinIO 对象存储
# ====================
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET_NAME=knowledge-bucket

# ====================
# MCP 网络搜索
# ====================
MCP_DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ====================
# 本地模型路径（可选）
# ====================
BGE_MODEL_PATH=./models/bge-m3
RERANK_MODEL_PATH=./models/bge-reranker-v2-m3

# ====================
# Agent 调试
# ====================
OPENAI_AGENTS_DISABLE_TRACING=1
